############################################################
# COPY THIS FILE TO: terraform.tfvars
# Then adjust the values below.
############################################################

subscription_id = "00000000-0000-0000-0000-000000000000"

project  = "testdc"
location = "westeurope"

vnet_address_space      = ["10.69.0.0/16"]
subnet_address_prefixes = ["10.69.0.0/24"]
vnet_dns_servers        = ["10.69.0.4", "168.63.129.16"]
internal_ip             = "10.69.0.4"

ad_forest_name      = "internal.justinverstijnen.nl"
domain_netbios_name = "JV-INT"

admin_username     = "jvadmin"
admin_password     = "ChangeM3-This-Password-Now!"
safe_mode_password = "ChangeM3-This-DSRM-Password-Now!"

vm_size      = "Standard_B2ms"
os_disk_type = "StandardSSD_LRS"

image_publisher = "MicrosoftWindowsServer"
image_offer     = "WindowsServer"
image_sku       = "2022-datacenter"
image_version   = "latest"

# Publish scripts/bootstrap-dc.ps1 to a public GitHub repository and paste the raw URL here.
# Example format:
# "https://raw.githubusercontent.com/<owner>/<repo>/main/scripts/bootstrap-dc.ps1"
bootstrap_script_url       = "https://raw.githubusercontent.com/<owner>/<repo>/main/scripts/bootstrap-dc.ps1"
bootstrap_script_file_name = "bootstrap-dc.ps1"
bootstrap_script_version   = "1"

# Recommended: replace these with your own public IP addresses and /32.
# Example: ["203.0.113.10/32", "203.0.113.11/32"]
# Temporary lab-only option: ["*"]
rdp_source_address_prefixes = ["YOUR.PUBLIC.IP.ADDRESS/32"]

time_zone = "W. Europe Standard Time"
culture   = "nl-NL"
geoid     = "176"

tags = {
  owner       = "Justin Verstijnen"
  environment = "lab"
  deployedBy  = "terraform"
}
